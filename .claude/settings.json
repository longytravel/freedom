{
  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(cargo *)",
      "Bash(rustfmt *)",
      "Bash(clippy *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(pre-commit *)"
    ],
    "deny": [
      "Bash(git push*--force*)",
      "Bash(git push*-f*)",
      "Bash(git push*--no-verify*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git commit*-n*)",
      "Bash(git commit*--amend*)",
      "Bash(git reset*--hard*)",
      "Bash(git checkout main)",
      "Bash(git switch main)",
      "Bash(gh pr merge*--admin*)",
      "Bash(gh api*branches/main/protection*--method DELETE*)",
      "Bash(gh api*branches/main/protection*-X DELETE*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-on-edit.sh\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/update-paperwork.sh\""
          }
        ]
      }
    ]
  }
}
